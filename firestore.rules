rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get the caller's user document
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: check if caller is admin
    function isAdmin() {
      return isAuth() && userData().role == 'admin';
    }

    // Helper: check if caller is the document owner
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─── Users ───
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() ||
        (isOwner(userId) &&
         request.resource.data.keys().hasOnly([
           'name',
           'email',
           'role',
           'isActive',
           'language',
           'createdAt'
         ]) &&
         request.resource.data.role == 'technician' &&
         request.resource.data.isActive == true &&
         request.resource.data.email == request.auth.token.email);
      // Admins can update anything; technicians can update their own language or name
      allow update: if isAdmin() ||
        (isOwner(userId) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['language', 'name']));
      allow delete: if false;
    }

    // ─── Jobs ───
    match /jobs/{jobId} {
      allow read: if isAuth() &&
        (resource.data.techId == request.auth.uid || isAdmin());

      allow create: if (isAuth() &&
        request.resource.data.techId == request.auth.uid &&
        request.resource.data.status == 'pending') ||
        (isAdmin() &&
          request.resource.data.status in ['pending', 'approved', 'rejected']);

      allow update: if (
        isAdmin() &&
        resource.data.status == 'pending' &&
        request.resource.data.techId == resource.data.techId &&
        request.resource.data.status in ['approved', 'rejected'] &&
        request.resource.data.approvedBy == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'approvedBy',
          'reviewedAt',
          'adminNote'
        ])
      ) || (
        isOwner(resource.data.techId) &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.techId == resource.data.techId &&
        request.resource.data.approvedBy == resource.data.approvedBy &&
        request.resource.data.reviewedAt == resource.data.reviewedAt &&
        request.resource.data.adminNote == resource.data.adminNote &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'techName',
          'companyId',
          'companyName',
          'invoiceNumber',
          'clientName',
          'clientContact',
          'acUnits',
          'charges',
          'date',
          'submittedAt',
          'expenses',
          'expenseNote'
        ])
      );

      allow delete: if false;
    }

    // ─── Expenses ───
    match /expenses/{expenseId} {
      // Techs read own; admins read all
      allow read: if isAuth() &&
        (resource.data.techId == request.auth.uid || isAdmin());

      // Techs create own expenses
      allow create: if isAuth() &&
        request.resource.data.techId == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'techId',
          'techName',
          'category',
          'amount',
          'note',
          'expenseType',
          'date',
          'createdAt'
        ]);

      allow update: if isAdmin() || (
        isAuth() &&
        resource.data.techId == request.auth.uid &&
        request.resource.data.techId == resource.data.techId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'techName',
          'category',
          'amount',
          'note',
          'expenseType',
          'date'
        ])
      );

      allow delete: if false;
    }

    // ─── Earnings ───
    match /earnings/{earningId} {
      // Techs read own; admins read all
      allow read: if isAuth() &&
        (resource.data.techId == request.auth.uid || isAdmin());

      // Techs create own earnings
      allow create: if isAuth() &&
        request.resource.data.techId == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'techId',
          'techName',
          'category',
          'amount',
          'note',
          'date',
          'createdAt'
        ]);

      allow update: if isAdmin() || (
        isAuth() &&
        resource.data.techId == request.auth.uid &&
        request.resource.data.techId == resource.data.techId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'techName',
          'category',
          'amount',
          'note',
          'date'
        ])
      );

      allow delete: if false;
    }

    // ─── Companies ───
    match /companies/{companyId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
  }
}
