rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    function authUidOrEmpty() {
      return request.auth != null ? request.auth.uid : '';
    }

    function userExists() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper: get the caller's user document
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: check if caller is admin
    function isAdmin() {
      return userExists() &&
        userData().role is string &&
        userData().role in [
          'admin',
          'administrator',
          'Admin',
          'Administrator',
          'ADMIN',
          'ADMINISTRATOR'
        ];
    }

    function isActiveUser() {
      return userExists() &&
        (!(userData().isActive is bool) || userData().isActive == true);
    }

    function approvalConfigDocPath() {
      return /databases/$(database)/documents/app_settings/approval_config;
    }

    function approvalConfigData() {
      return get(approvalConfigDocPath()).data;
    }

    function jobApprovalRequired() {
      return !exists(approvalConfigDocPath()) ||
        !(approvalConfigData().jobApprovalRequired is bool) ||
        approvalConfigData().jobApprovalRequired;
    }

    function inOutApprovalRequired() {
      return !exists(approvalConfigDocPath()) ||
        !(approvalConfigData().inOutApprovalRequired is bool) ||
        approvalConfigData().inOutApprovalRequired;
    }

    function sharedJobApprovalRequired() {
      return !exists(approvalConfigDocPath()) ||
        !(approvalConfigData().sharedJobApprovalRequired is bool) ||
        approvalConfigData().sharedJobApprovalRequired;
    }

    function hasLockedBefore() {
      return exists(approvalConfigDocPath()) &&
        approvalConfigData().keys().hasAny(['lockedBefore']) &&
        approvalConfigData().lockedBefore is timestamp;
    }

    function dateIsUnlocked(dateValue) {
      return !(dateValue is timestamp) ||
        !hasLockedBefore() ||
        dateValue >= approvalConfigData().lockedBefore;
    }

    function isSharedJobCreate() {
      return request.resource.data.isSharedInstall is bool &&
        request.resource.data.isSharedInstall;
    }

    function invoiceClaimDocPath(invoiceNumber) {
      return /databases/$(database)/documents/invoice_claims/$(invoiceNumber.lower());
    }

    function invoiceClaimAfterData() {
      return getAfter(invoiceClaimDocPath(request.resource.data.invoiceNumber)).data;
    }

    function invoiceClaimAfterExists() {
      return existsAfter(invoiceClaimDocPath(request.resource.data.invoiceNumber));
    }

    function requestedInvoiceReuseMode() {
      return isSharedJobCreate() ? 'shared' : 'solo';
    }

    function validInvoiceClaimState() {
      return invoiceClaimAfterExists() &&
        invoiceClaimAfterData().invoiceNumber == request.resource.data.invoiceNumber &&
        invoiceClaimAfterData().companyId == request.resource.data.companyId &&
        invoiceClaimAfterData().companyName == request.resource.data.companyName &&
        invoiceClaimAfterData().reuseMode == requestedInvoiceReuseMode() &&
        (invoiceClaimAfterData().createdBy == request.auth.uid || isAdmin()) &&
        invoiceClaimAfterData().activeJobCount is int &&
        invoiceClaimAfterData().activeJobCount > 0 &&
        invoiceClaimAfterData().createdAt is timestamp &&
        invoiceClaimAfterData().updatedAt is timestamp;
    }

    function invoiceClaimHasAllowedKeys(data) {
      return data.keys().hasOnly([
        'invoiceNumber',
        'companyId',
        'companyName',
        'reuseMode',
        'activeJobCount',
        'createdBy',
        'createdAt',
        'updatedAt'
      ]);
    }

    function validInvoiceClaimModes(data) {
      return data.reuseMode in ['shared', 'solo'];
    }

    function invoiceClaimImmutableFieldsUnchanged() {
      return request.resource.data.invoiceNumber == resource.data.invoiceNumber &&
        request.resource.data.companyId == resource.data.companyId &&
        request.resource.data.companyName == resource.data.companyName &&
        request.resource.data.reuseMode == resource.data.reuseMode &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function isNonSharedJobCreate() {
      return request.resource.data.isSharedInstall is bool &&
        !request.resource.data.isSharedInstall;
    }

    function validSharedInstallFields() {
      return request.resource.data.isSharedInstall is bool &&
        request.resource.data.isSharedInstall &&
        request.resource.data.sharedInstallGroupKey is string &&
        request.resource.data.sharedInvoiceTotalUnits is int &&
        request.resource.data.sharedInvoiceTotalUnits >= 0 &&
        request.resource.data.sharedContributionUnits is int &&
        request.resource.data.sharedContributionUnits >= 0 &&
        request.resource.data.sharedInvoiceSplitUnits is int &&
        request.resource.data.sharedInvoiceSplitUnits >= 0 &&
        request.resource.data.sharedInvoiceWindowUnits is int &&
        request.resource.data.sharedInvoiceWindowUnits >= 0 &&
        request.resource.data.sharedInvoiceFreestandingUnits is int &&
        request.resource.data.sharedInvoiceFreestandingUnits >= 0 &&
        request.resource.data.sharedInvoiceUninstallSplitUnits is int &&
        request.resource.data.sharedInvoiceUninstallSplitUnits >= 0 &&
        request.resource.data.sharedInvoiceUninstallWindowUnits is int &&
        request.resource.data.sharedInvoiceUninstallWindowUnits >= 0 &&
        request.resource.data.sharedInvoiceUninstallFreestandingUnits is int &&
        request.resource.data.sharedInvoiceUninstallFreestandingUnits >= 0 &&
        request.resource.data.sharedInvoiceBracketCount is int &&
        request.resource.data.sharedInvoiceBracketCount >= 0 &&
        request.resource.data.sharedDeliveryTeamCount is int &&
        request.resource.data.sharedDeliveryTeamCount >= 0 &&
        request.resource.data.sharedInvoiceDeliveryAmount is number &&
        request.resource.data.sharedInvoiceDeliveryAmount >= 0 &&
        request.resource.data.sharedInvoiceDeliveryAmount <= 1000000 &&
        request.resource.data.techSplitShare is int &&
        request.resource.data.techSplitShare >= 0 &&
        request.resource.data.techWindowShare is int &&
        request.resource.data.techWindowShare >= 0 &&
        request.resource.data.techFreestandingShare is int &&
        request.resource.data.techFreestandingShare >= 0 &&
        request.resource.data.techUninstallSplitShare is int &&
        request.resource.data.techUninstallSplitShare >= 0 &&
        request.resource.data.techUninstallWindowShare is int &&
        request.resource.data.techUninstallWindowShare >= 0 &&
        request.resource.data.techUninstallFreestandingShare is int &&
        request.resource.data.techUninstallFreestandingShare >= 0 &&
        request.resource.data.techBracketShare is int &&
        request.resource.data.techBracketShare >= 0;
    }

    function validJobSharedState() {
      return isNonSharedJobCreate() || validSharedInstallFields();
    }

    function validJobCreatePayload() {
      return request.resource.data.keys().hasAll([
        'techId',
        'techName',
        'companyId',
        'companyName',
        'invoiceNumber',
        'clientName',
        'acUnits',
        'status',
        'expenses',
        'date',
        'submittedAt'
      ]) &&
      request.resource.data.companyId is string &&
      request.resource.data.companyName is string &&
      request.resource.data.invoiceNumber is string &&
      request.resource.data.invoiceNumber.size() > 0 &&
      request.resource.data.clientName is string &&
      request.resource.data.acUnits is list &&
      request.resource.data.acUnits.size() > 0 &&
      request.resource.data.expenses is number &&
      request.resource.data.expenses >= 0 &&
      request.resource.data.expenses <= 1000000;
    }

    function settlementStatusOf(data) {
      return data.keys().hasAny(['settlementStatus']) && data.settlementStatus is string
        ? data.settlementStatus
        : 'unpaid';
    }

    function settlementFieldsUnchanged() {
      return settlementStatusOf(request.resource.data) == settlementStatusOf(resource.data) &&
        request.resource.data.get('settlementBatchId', null) == resource.data.get('settlementBatchId', null) &&
        request.resource.data.get('settlementRound', null) == resource.data.get('settlementRound', null) &&
        request.resource.data.get('settlementAdminNote', null) == resource.data.get('settlementAdminNote', null) &&
        request.resource.data.get('settlementTechnicianComment', null) == resource.data.get('settlementTechnicianComment', null) &&
        request.resource.data.get('settlementRequestedBy', null) == resource.data.get('settlementRequestedBy', null) &&
        request.resource.data.get('settlementAmount', null) == resource.data.get('settlementAmount', null) &&
        request.resource.data.get('settlementPaymentMethod', null) == resource.data.get('settlementPaymentMethod', null) &&
        request.resource.data.get('settlementRequestedAt', null) == resource.data.get('settlementRequestedAt', null) &&
        request.resource.data.get('settlementRespondedAt', null) == resource.data.get('settlementRespondedAt', null) &&
        request.resource.data.get('settlementPaidAt', null) == resource.data.get('settlementPaidAt', null) &&
        request.resource.data.get('settlementCorrectedAt', null) == resource.data.get('settlementCorrectedAt', null);
    }

    function settlementFieldsOnlyChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'settlementStatus',
        'settlementBatchId',
        'settlementRound',
        'settlementAmount',
        'settlementPaymentMethod',
        'settlementAdminNote',
        'settlementTechnicianComment',
        'settlementRequestedBy',
        'settlementRequestedAt',
        'settlementRespondedAt',
        'settlementPaidAt',
        'settlementCorrectedAt'
      ]);
    }

    function technicianExpectedEditedStatus() {
      return (request.resource.data.isSharedInstall is bool && request.resource.data.isSharedInstall)
        ? (sharedJobApprovalRequired() ? 'pending' : 'approved')
        : (jobApprovalRequired() ? 'pending' : 'approved');
    }

    function technicianCanEditApprovedJob() {
      return resource.data.status == 'approved' &&
        settlementStatusOf(resource.data) == 'unpaid' &&
        ((resource.data.isSharedInstall is bool && resource.data.isSharedInstall)
          ? !sharedJobApprovalRequired()
          : !jobApprovalRequired());
    }

    function technicianMutableJobUpdate() {
      return isActiveUser() &&
        isOwner(resource.data.techId) &&
        request.resource.data.techId == resource.data.techId &&
        request.resource.data.submittedAt == resource.data.submittedAt &&
        dateIsUnlocked(resource.data.date) &&
        dateIsUnlocked(request.resource.data.date) &&
        validJobSharedState() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'techName',
          'companyId',
          'companyName',
          'invoiceNumber',
          'clientName',
          'clientContact',
          'acUnits',
          'isSharedInstall',
          'sharedInstallGroupKey',
          'sharedInvoiceTotalUnits',
          'sharedContributionUnits',
          'sharedInvoiceSplitUnits',
          'sharedInvoiceWindowUnits',
          'sharedInvoiceFreestandingUnits',
          'sharedInvoiceUninstallSplitUnits',
          'sharedInvoiceUninstallWindowUnits',
          'sharedInvoiceUninstallFreestandingUnits',
          'sharedInvoiceBracketCount',
          'sharedDeliveryTeamCount',
          'sharedInvoiceDeliveryAmount',
          'techSplitShare',
          'techWindowShare',
          'techFreestandingShare',
          'techUninstallSplitShare',
          'techUninstallWindowShare',
          'techUninstallFreestandingShare',
          'techBracketShare',
          'charges',
          'date',
          'expenses',
          'expenseNote',
          'status',
          'approvedBy',
          'reviewedAt',
          'adminNote'
        ]);
    }

    function technicianApprovalFlowUpdate() {
      return technicianMutableJobUpdate() && (
        (
          resource.data.status == 'pending' &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.approvedBy == resource.data.approvedBy &&
          request.resource.data.reviewedAt == resource.data.reviewedAt &&
          request.resource.data.adminNote == resource.data.adminNote &&
          settlementFieldsUnchanged()
        ) || (
          resource.data.status == 'rejected' &&
          request.resource.data.status == technicianExpectedEditedStatus() &&
          request.resource.data.approvedBy == null &&
          request.resource.data.reviewedAt == null &&
          request.resource.data.adminNote == '' &&
          settlementStatusOf(request.resource.data) == 'unpaid'
        ) || (
          technicianCanEditApprovedJob() &&
          request.resource.data.status == 'approved' &&
          request.resource.data.approvedBy == resource.data.approvedBy &&
          request.resource.data.reviewedAt == resource.data.reviewedAt &&
          request.resource.data.adminNote == resource.data.adminNote &&
          settlementFieldsUnchanged()
        )
      );
    }

    function adminSettlementUpdate() {
      return isAdmin() &&
        resource.data.status == 'approved' &&
        request.resource.data.status == resource.data.status &&
        settlementFieldsOnlyChanged() &&
        dateIsUnlocked(resource.data.date) &&
        validAdminSettlementTransition();
    }

    function technicianSettlementUpdate() {
      return isActiveUser() &&
        isOwner(resource.data.techId) &&
        resource.data.status == 'approved' &&
        settlementStatusOf(resource.data) == 'awaiting_technician' &&
        settlementFieldsOnlyChanged() &&
        dateIsUnlocked(resource.data.date) &&
        validTechSettlementTransition();
    }

    function technicianJobCreateAllowed() {
      return isActiveUser() &&
        dateIsUnlocked(request.resource.data.date) &&
        request.resource.data.techId == request.auth.uid &&
        request.resource.data.status == (
          isSharedJobCreate()
            ? (sharedJobApprovalRequired() ? 'pending' : 'approved')
            : (jobApprovalRequired() ? 'pending' : 'approved')
        ) &&
        validJobCreatePayload() &&
        validJobSharedState() &&
        validInvoiceClaimState();
    }

    function adminJobCreateAllowed() {
      return dateIsUnlocked(request.resource.data.date) &&
        validJobCreatePayload() &&
        validJobSharedState() &&
        validInvoiceClaimState() &&
        request.resource.data.status in ['pending', 'approved', 'rejected'];
    }

    function adminGeneralJobUpdateAllowed() {
      return dateIsUnlocked(resource.data.date) &&
        dateIsUnlocked(request.resource.data.date) &&
        resource.data.status != 'approved';
    }

    function jobUpdateAllowed() {
      return isAdmin()
        ? (adminSettlementUpdate() || adminGeneralJobUpdateAllowed())
        : (technicianSettlementUpdate() || technicianApprovalFlowUpdate());
    }

    function validAdminSettlementTransition() {
      return (
        settlementStatusOf(resource.data) == 'unpaid' &&
        settlementStatusOf(request.resource.data) == 'awaiting_technician' &&
        request.resource.data.settlementRound == 1 &&
        request.resource.data.settlementAmount is number &&
        request.resource.data.settlementAmount >= 0 &&
        request.resource.data.settlementPaymentMethod is string &&
        request.resource.data.settlementPaymentMethod.size() > 0 &&
        request.resource.data.settlementBatchId is string &&
        request.resource.data.settlementBatchId.size() > 0 &&
        request.resource.data.settlementRequestedBy == request.auth.uid &&
        request.resource.data.settlementRequestedAt is timestamp &&
        request.resource.data.settlementRespondedAt == null &&
        request.resource.data.settlementPaidAt is timestamp &&
        request.resource.data.settlementCorrectedAt == null &&
        request.resource.data.settlementTechnicianComment is string
      ) || (
        settlementStatusOf(resource.data) == 'correction_required' &&
        settlementStatusOf(request.resource.data) == 'awaiting_technician' &&
        request.resource.data.settlementRound == 2 &&
        request.resource.data.get('settlementAmount', null) == resource.data.get('settlementAmount', null) &&
        request.resource.data.get('settlementPaymentMethod', null) == resource.data.get('settlementPaymentMethod', null) &&
        request.resource.data.get('settlementBatchId', null) == resource.data.get('settlementBatchId', null) &&
        request.resource.data.get('settlementRequestedBy', null) == request.auth.uid &&
        request.resource.data.settlementRequestedAt is timestamp &&
        request.resource.data.settlementRespondedAt == null &&
        request.resource.data.get('settlementPaidAt', null) == resource.data.get('settlementPaidAt', null) &&
        request.resource.data.settlementCorrectedAt is timestamp
      ) || (
        settlementStatusOf(resource.data) == 'disputed_final' &&
        settlementStatusOf(request.resource.data) == 'confirmed' &&
        request.resource.data.get('settlementRound', null) == resource.data.get('settlementRound', null) &&
        request.resource.data.get('settlementAmount', null) == resource.data.get('settlementAmount', null) &&
        request.resource.data.get('settlementPaymentMethod', null) == resource.data.get('settlementPaymentMethod', null) &&
        request.resource.data.get('settlementBatchId', null) == resource.data.get('settlementBatchId', null) &&
        request.resource.data.get('settlementRequestedBy', null) == resource.data.get('settlementRequestedBy', null) &&
        request.resource.data.get('settlementRequestedAt', null) == resource.data.get('settlementRequestedAt', null) &&
        request.resource.data.get('settlementRespondedAt', null) == resource.data.get('settlementRespondedAt', null) &&
        request.resource.data.get('settlementPaidAt', null) == resource.data.get('settlementPaidAt', null) &&
        request.resource.data.settlementCorrectedAt is timestamp
      );
    }

    function validTechSettlementTransition() {
      return request.resource.data.get('settlementBatchId', null) == resource.data.get('settlementBatchId', null) &&
        request.resource.data.get('settlementRound', null) == resource.data.get('settlementRound', null) &&
        request.resource.data.get('settlementAmount', null) == resource.data.get('settlementAmount', null) &&
        request.resource.data.get('settlementPaymentMethod', null) == resource.data.get('settlementPaymentMethod', null) &&
        request.resource.data.get('settlementAdminNote', null) == resource.data.get('settlementAdminNote', null) &&
        request.resource.data.get('settlementRequestedBy', null) == resource.data.get('settlementRequestedBy', null) &&
        request.resource.data.get('settlementRequestedAt', null) == resource.data.get('settlementRequestedAt', null) &&
        request.resource.data.get('settlementCorrectedAt', null) == resource.data.get('settlementCorrectedAt', null) &&
        request.resource.data.get('settlementPaidAt', null) == resource.data.get('settlementPaidAt', null) &&
        request.resource.data.settlementRespondedAt is timestamp &&
        (
          settlementStatusOf(request.resource.data) == 'confirmed' ||
          (
            settlementStatusOf(request.resource.data) == 'correction_required' &&
            request.resource.data.settlementRound < 2 &&
            request.resource.data.settlementTechnicianComment is string &&
            request.resource.data.settlementTechnicianComment.size() > 0
          ) ||
          (
            settlementStatusOf(request.resource.data) == 'disputed_final' &&
            request.resource.data.settlementRound >= 2 &&
            request.resource.data.settlementTechnicianComment is string &&
            request.resource.data.settlementTechnicianComment.size() > 0
          )
        );
    }

    function validSharedAggregateTotals(data) {
      return data.sharedInvoiceSplitUnits is int &&
        data.sharedInvoiceSplitUnits >= 0 &&
        data.sharedInvoiceWindowUnits is int &&
        data.sharedInvoiceWindowUnits >= 0 &&
        data.sharedInvoiceFreestandingUnits is int &&
        data.sharedInvoiceFreestandingUnits >= 0 &&
        data.sharedInvoiceUninstallSplitUnits is int &&
        data.sharedInvoiceUninstallSplitUnits >= 0 &&
        data.sharedInvoiceUninstallWindowUnits is int &&
        data.sharedInvoiceUninstallWindowUnits >= 0 &&
        data.sharedInvoiceUninstallFreestandingUnits is int &&
        data.sharedInvoiceUninstallFreestandingUnits >= 0 &&
        data.sharedInvoiceBracketCount is int &&
        data.sharedInvoiceBracketCount >= 0 &&
        data.sharedDeliveryTeamCount is int &&
        data.sharedDeliveryTeamCount >= 0 &&
        data.sharedInvoiceDeliveryAmount is number &&
        data.sharedInvoiceDeliveryAmount >= 0 &&
        data.consumedSplitUnits is int &&
        data.consumedSplitUnits >= 0 &&
        data.consumedSplitUnits <= data.sharedInvoiceSplitUnits &&
        data.consumedWindowUnits is int &&
        data.consumedWindowUnits >= 0 &&
        data.consumedWindowUnits <= data.sharedInvoiceWindowUnits &&
        data.consumedFreestandingUnits is int &&
        data.consumedFreestandingUnits >= 0 &&
        data.consumedFreestandingUnits <= data.sharedInvoiceFreestandingUnits &&
        data.consumedUninstallSplitUnits is int &&
        data.consumedUninstallSplitUnits >= 0 &&
        data.consumedUninstallSplitUnits <= data.sharedInvoiceUninstallSplitUnits &&
        data.consumedUninstallWindowUnits is int &&
        data.consumedUninstallWindowUnits >= 0 &&
        data.consumedUninstallWindowUnits <= data.sharedInvoiceUninstallWindowUnits &&
        data.consumedUninstallFreestandingUnits is int &&
        data.consumedUninstallFreestandingUnits >= 0 &&
        data.consumedUninstallFreestandingUnits <= data.sharedInvoiceUninstallFreestandingUnits &&
        data.consumedBracketCount is int &&
        data.consumedBracketCount >= 0 &&
        data.consumedBracketCount <= data.sharedInvoiceBracketCount &&
        data.consumedDeliveryAmount is number &&
        data.consumedDeliveryAmount >= 0 &&
        data.consumedDeliveryAmount <= data.sharedInvoiceDeliveryAmount + 0.01;
    }

    function validSharedAggregateCreatePayload() {
      return request.resource.data.keys().hasOnly([
          'groupKey',
          'companyId',
          'companyName',
          'clientName',
          'clientContact',
          'sharedInvoiceSplitUnits',
          'sharedInvoiceWindowUnits',
          'sharedInvoiceFreestandingUnits',
          'sharedInvoiceUninstallSplitUnits',
          'sharedInvoiceUninstallWindowUnits',
          'sharedInvoiceUninstallFreestandingUnits',
          'sharedInvoiceBracketCount',
          'sharedDeliveryTeamCount',
          'sharedInvoiceDeliveryAmount',
          'consumedSplitUnits',
          'consumedWindowUnits',
          'consumedFreestandingUnits',
          'consumedUninstallSplitUnits',
          'consumedUninstallWindowUnits',
          'consumedUninstallFreestandingUnits',
          'consumedBracketCount',
          'consumedDeliveryAmount',
          'createdBy',
          'createdAt',
          'updatedAt',
          'teamMemberIds',
          'teamMemberNames'
        ]) &&
        request.resource.data.get('clientName', '') is string &&
        request.resource.data.get('clientContact', '') is string &&
        request.resource.data.groupKey is string &&
        request.resource.data.groupKey.size() > 0 &&
        request.resource.data.get('companyId', '') is string &&
        request.resource.data.get('companyName', '') is string &&
        request.resource.data.sharedInvoiceSplitUnits is int &&
        request.resource.data.sharedInvoiceSplitUnits >= 0 &&
        request.resource.data.sharedInvoiceWindowUnits is int &&
        request.resource.data.sharedInvoiceWindowUnits >= 0 &&
        request.resource.data.sharedInvoiceFreestandingUnits is int &&
        request.resource.data.sharedInvoiceFreestandingUnits >= 0 &&
        request.resource.data.sharedInvoiceUninstallSplitUnits is int &&
        request.resource.data.sharedInvoiceUninstallSplitUnits >= 0 &&
        request.resource.data.sharedInvoiceUninstallWindowUnits is int &&
        request.resource.data.sharedInvoiceUninstallWindowUnits >= 0 &&
        request.resource.data.sharedInvoiceUninstallFreestandingUnits is int &&
        request.resource.data.sharedInvoiceUninstallFreestandingUnits >= 0 &&
        request.resource.data.sharedInvoiceBracketCount is int &&
        request.resource.data.sharedInvoiceBracketCount >= 0 &&
        request.resource.data.sharedDeliveryTeamCount is int &&
        request.resource.data.sharedDeliveryTeamCount >= 0 &&
        request.resource.data.sharedInvoiceDeliveryAmount is number &&
        request.resource.data.sharedInvoiceDeliveryAmount >= 0 &&
        request.resource.data.consumedSplitUnits is int &&
        request.resource.data.consumedSplitUnits >= 0 &&
        request.resource.data.consumedWindowUnits is int &&
        request.resource.data.consumedWindowUnits >= 0 &&
        request.resource.data.consumedFreestandingUnits is int &&
        request.resource.data.consumedFreestandingUnits >= 0 &&
        request.resource.data.consumedUninstallSplitUnits is int &&
        request.resource.data.consumedUninstallSplitUnits >= 0 &&
        request.resource.data.consumedUninstallWindowUnits is int &&
        request.resource.data.consumedUninstallWindowUnits >= 0 &&
        request.resource.data.consumedUninstallFreestandingUnits is int &&
        request.resource.data.consumedUninstallFreestandingUnits >= 0 &&
        request.resource.data.consumedBracketCount is int &&
        request.resource.data.consumedBracketCount >= 0 &&
        request.resource.data.consumedDeliveryAmount is number &&
        request.resource.data.consumedDeliveryAmount >= 0 &&
        request.resource.data.createdBy is string &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        // Team roster: must include creator as first member, max 10
        request.resource.data.teamMemberIds is list &&
        request.resource.data.teamMemberIds.size() >= 1 &&
        request.resource.data.teamMemberIds.size() <= 10 &&
        request.resource.data.teamMemberIds[0] == request.auth.uid &&
        request.resource.data.teamMemberNames is list &&
        request.resource.data.teamMemberNames.size() == request.resource.data.teamMemberIds.size() &&
        validSharedAggregateTotals(request.resource.data);
    }

    function sharedAggregateStaticFieldsUnchanged() {
      return request.resource.data.groupKey == resource.data.groupKey &&
        request.resource.data.sharedInvoiceSplitUnits == resource.data.sharedInvoiceSplitUnits &&
        request.resource.data.sharedInvoiceWindowUnits == resource.data.sharedInvoiceWindowUnits &&
        request.resource.data.sharedInvoiceFreestandingUnits == resource.data.sharedInvoiceFreestandingUnits &&
        request.resource.data.sharedInvoiceUninstallSplitUnits == resource.data.sharedInvoiceUninstallSplitUnits &&
        request.resource.data.sharedInvoiceUninstallWindowUnits == resource.data.sharedInvoiceUninstallWindowUnits &&
        request.resource.data.sharedInvoiceUninstallFreestandingUnits == resource.data.sharedInvoiceUninstallFreestandingUnits &&
        request.resource.data.sharedInvoiceBracketCount == resource.data.sharedInvoiceBracketCount &&
        request.resource.data.sharedDeliveryTeamCount == resource.data.sharedDeliveryTeamCount &&
        request.resource.data.sharedInvoiceDeliveryAmount == resource.data.sharedInvoiceDeliveryAmount &&
        resource.data.get('companyId', '') == request.resource.data.get('companyId', '') &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function validSharedAggregateAdminUpdatePayload() {
      return request.resource.data.keys().hasOnly([
          'groupKey',
          'companyId',
          'companyName',
          'clientName',
          'clientContact',
          'sharedInvoiceSplitUnits',
          'sharedInvoiceWindowUnits',
          'sharedInvoiceFreestandingUnits',
          'sharedInvoiceUninstallSplitUnits',
          'sharedInvoiceUninstallWindowUnits',
          'sharedInvoiceUninstallFreestandingUnits',
          'sharedInvoiceBracketCount',
          'sharedDeliveryTeamCount',
          'sharedInvoiceDeliveryAmount',
          'consumedSplitUnits',
          'consumedWindowUnits',
          'consumedFreestandingUnits',
          'consumedUninstallSplitUnits',
          'consumedUninstallWindowUnits',
          'consumedUninstallFreestandingUnits',
          'consumedBracketCount',
          'consumedDeliveryAmount',
          'createdBy',
          'createdAt',
          'updatedAt',
          'teamMemberIds',
          'teamMemberNames'
        ]) &&
        sharedAggregateStaticFieldsUnchanged() &&
        request.resource.data.updatedAt is timestamp &&
        validSharedAggregateTotals(request.resource.data);
    }

    function sharedAggregateUpdateAllowed() {
      return isAdmin()
        ? validSharedAggregateAdminUpdatePayload()
        : (isActiveUser() && validSharedAggregateTechUpdatePayload());
    }

    function validSharedAggregateTechUpdatePayload() {
      return request.resource.data.keys().hasOnly([
          'groupKey',
          'companyId',
          'companyName',
          'clientName',
          'clientContact',
          'sharedInvoiceSplitUnits',
          'sharedInvoiceWindowUnits',
          'sharedInvoiceFreestandingUnits',
          'sharedInvoiceUninstallSplitUnits',
          'sharedInvoiceUninstallWindowUnits',
          'sharedInvoiceUninstallFreestandingUnits',
          'sharedInvoiceBracketCount',
          'sharedDeliveryTeamCount',
          'sharedInvoiceDeliveryAmount',
          'consumedSplitUnits',
          'consumedWindowUnits',
          'consumedFreestandingUnits',
          'consumedUninstallSplitUnits',
          'consumedUninstallWindowUnits',
          'consumedUninstallFreestandingUnits',
          'consumedBracketCount',
          'consumedDeliveryAmount',
          'createdBy',
          'createdAt',
          'updatedAt',
          'teamMemberIds',
          'teamMemberNames'
        ]) &&
        request.resource.data.get('clientName', '') is string &&
        request.resource.data.get('clientContact', '') is string &&
        // Any team member may submit their contribution (not just the creator)
        authUidOrEmpty() in resource.data.get('teamMemberIds', [resource.data.createdBy]) &&
        sharedAggregateStaticFieldsUnchanged() &&
        // Team membership is immutable for techs — only admin can change it
        request.resource.data.get('teamMemberIds', []) == resource.data.get('teamMemberIds', []) &&
        request.resource.data.get('teamMemberNames', []) == resource.data.get('teamMemberNames', []) &&
        request.resource.data.updatedAt is timestamp &&
        request.resource.data.consumedSplitUnits is int &&
        request.resource.data.consumedSplitUnits >= resource.data.consumedSplitUnits &&
        request.resource.data.consumedSplitUnits <= resource.data.sharedInvoiceSplitUnits &&
        request.resource.data.consumedWindowUnits is int &&
        request.resource.data.consumedWindowUnits >= resource.data.consumedWindowUnits &&
        request.resource.data.consumedWindowUnits <= resource.data.sharedInvoiceWindowUnits &&
        request.resource.data.consumedFreestandingUnits is int &&
        request.resource.data.consumedFreestandingUnits >= resource.data.consumedFreestandingUnits &&
        request.resource.data.consumedFreestandingUnits <= resource.data.sharedInvoiceFreestandingUnits &&
        request.resource.data.consumedUninstallSplitUnits is int &&
        request.resource.data.consumedUninstallSplitUnits >= resource.data.consumedUninstallSplitUnits &&
        request.resource.data.consumedUninstallSplitUnits <= resource.data.sharedInvoiceUninstallSplitUnits &&
        request.resource.data.consumedUninstallWindowUnits is int &&
        request.resource.data.consumedUninstallWindowUnits >= resource.data.consumedUninstallWindowUnits &&
        request.resource.data.consumedUninstallWindowUnits <= resource.data.sharedInvoiceUninstallWindowUnits &&
        request.resource.data.consumedUninstallFreestandingUnits is int &&
        request.resource.data.consumedUninstallFreestandingUnits >= resource.data.consumedUninstallFreestandingUnits &&
        request.resource.data.consumedUninstallFreestandingUnits <= resource.data.sharedInvoiceUninstallFreestandingUnits &&
        request.resource.data.consumedBracketCount is int &&
        request.resource.data.consumedBracketCount >= resource.data.consumedBracketCount &&
        request.resource.data.consumedBracketCount <= resource.data.sharedInvoiceBracketCount &&
        request.resource.data.consumedDeliveryAmount is number &&
        request.resource.data.consumedDeliveryAmount >= resource.data.consumedDeliveryAmount &&
        request.resource.data.consumedDeliveryAmount <= resource.data.sharedInvoiceDeliveryAmount + 0.01;
    }

    function invoiceClaimCreatePayloadAllowed() {
      return (isAdmin() || isActiveUser()) &&
        request.resource.data.keys().hasAll([
          'invoiceNumber',
          'companyId',
          'companyName',
          'reuseMode',
          'activeJobCount',
          'createdBy',
          'createdAt',
          'updatedAt'
        ]) &&
        invoiceClaimHasAllowedKeys(request.resource.data) &&
        request.resource.data.companyId is string &&
        request.resource.data.companyName is string &&
        validInvoiceClaimModes(request.resource.data) &&
        request.resource.data.activeJobCount is int &&
        request.resource.data.activeJobCount > 0 &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        (
          isAdmin() || (
            isActiveUser() &&
            request.resource.data.createdBy == authUidOrEmpty()
          )
        );
    }

    function invoiceClaimUpdateAllowed() {
      return (isAdmin() || isActiveUser()) &&
        request.resource.data.keys().hasAll([
          'invoiceNumber',
          'companyId',
          'companyName',
          'reuseMode',
          'activeJobCount',
          'createdBy',
          'createdAt',
          'updatedAt'
        ]) &&
        invoiceClaimHasAllowedKeys(request.resource.data) &&
        invoiceClaimImmutableFieldsUnchanged() &&
        request.resource.data.activeJobCount is int &&
        request.resource.data.activeJobCount >= 0 &&
        request.resource.data.updatedAt is timestamp &&
        (
          isAdmin() || (
            isActiveUser() &&
            request.resource.data.activeJobCount >= resource.data.activeJobCount - 1 &&
            request.resource.data.activeJobCount <= resource.data.activeJobCount + 1
          )
        );
    }

    // Helper: check if caller is the document owner
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─── Users ───
    match /users/{userId} {
      // get: own profile or admin
      allow get: if isOwner(userId) || isAdmin();
      // list: any active user may query the users collection (needed for team selector dropdown)
      // Safe: this is a closed private employee system — all users are company staff
      allow list: if isAdmin() || isActiveUser();
      allow create: if isAdmin();
      // Admins can update anything; users can update their own profile fields.
      allow update: if isAdmin() ||
        (isOwner(userId) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['language', 'name']));
      allow delete: if isAdmin();
    }

    // ─── Jobs ───
    match /jobs/{jobId} {
      allow read: if isAdmin() ||
        (isActiveUser() && resource.data.techId == request.auth.uid);

      match /history/{historyId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      allow create: if isAdmin()
        ? adminJobCreateAllowed()
        : technicianJobCreateAllowed();

      allow update: if jobUpdateAllowed();

      allow delete: if (isAdmin() &&
        dateIsUnlocked(resource.data.date) &&
        resource.data.status != 'approved') ||
        (isActiveUser() &&
         dateIsUnlocked(resource.data.date) &&
         resource.data.techId == request.auth.uid &&
         resource.data.status != 'approved' &&
         !(resource.data.isSharedInstall is bool && resource.data.isSharedInstall));
    }

    match /shared_install_aggregates/{aggregateId} {
      allow get: if isAdmin() || isActiveUser();
      // Active users may list (needed for arrayContains teamMemberIds query)
      allow list: if isAdmin() || isActiveUser();

      allow create: if (isAdmin() || isActiveUser()) &&
        validSharedAggregateCreatePayload();
      allow update: if sharedAggregateUpdateAllowed();
      allow delete: if isAdmin();
    }

    match /invoice_claims/{claimId} {
      allow get: if isAdmin() || isActiveUser();
      allow list: if isAdmin();

      allow create: if request.resource.data.invoiceNumber is string &&
        request.resource.data.invoiceNumber.lower() == claimId &&
        invoiceClaimCreatePayloadAllowed();

      allow update: if invoiceClaimUpdateAllowed();

      allow delete: if isAdmin();
    }

    // ─── Expenses ───
    match /expenses/{expenseId} {
      match /history/{historyId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      // Techs read own; admins read all
      allow read: if isAdmin() ||
        (isActiveUser() && resource.data.techId == request.auth.uid);

      // Techs create own expenses
      allow create: if isActiveUser() &&
        dateIsUnlocked(request.resource.data.date) &&
        request.resource.data.techId == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'techId',
          'techName',
          'category',
          'amount',
          'note',
          'expenseType',
          'status',
          'approvedBy',
          'adminNote',
          'date',
          'createdAt',
          'reviewedAt'
        ]) &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0 &&
        request.resource.data.amount <= 1000000 &&
        request.resource.data.expenseType in ['work', 'home'] &&
        request.resource.data.date is timestamp &&
        request.resource.data.approvedBy is string &&
        request.resource.data.adminNote is string &&
        (
          (inOutApprovalRequired() &&
            request.resource.data.status == 'pending' &&
            request.resource.data.approvedBy == '' &&
            request.resource.data.adminNote == '' &&
            request.resource.data.reviewedAt == null) ||
          (!inOutApprovalRequired() &&
            request.resource.data.status == 'approved' &&
            request.resource.data.reviewedAt is timestamp)
        );

      allow update: if (isAdmin() &&
        dateIsUnlocked(resource.data.date) &&
        dateIsUnlocked(request.resource.data.date) &&
        resource.data.status != 'approved') || (
        isActiveUser() &&
        dateIsUnlocked(resource.data.date) &&
        dateIsUnlocked(request.resource.data.date) &&
        resource.data.status == 'pending' &&
        resource.data.techId == request.auth.uid &&
        request.resource.data.techId == resource.data.techId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        inOutApprovalRequired() &&
        request.resource.data.status == 'pending' &&
        request.resource.data.approvedBy == '' &&
        request.resource.data.adminNote == '' &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'techName',
          'category',
          'amount',
          'note',
          'expenseType',
          'date',
          'status',
          'approvedBy',
          'adminNote',
          'reviewedAt'
        ])
      ) ||
      // Tech soft-archive: set isDeleted=true only, must not be approved, date unlocked
      (isActiveUser() &&
        resource.data.techId == request.auth.uid &&
        dateIsUnlocked(resource.data.date) &&
        resource.data.status != 'approved' &&
        request.resource.data.isDeleted == true &&
        request.resource.data.deletedAt is timestamp &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt'])
      ) ||
      // Admin restore: clear isDeleted flag
      (isAdmin() &&
        request.resource.data.isDeleted == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt'])
      );

      // Hard delete: admin only — techs must use archiveExpense() soft-delete instead
      allow delete: if isAdmin() &&
        dateIsUnlocked(resource.data.date) &&
        resource.data.status != 'approved';
    }

    // ─── Earnings ───
    match /earnings/{earningId} {
      match /history/{historyId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      // Techs read own; admins read all
      allow read: if isAdmin() ||
        (isActiveUser() && resource.data.techId == request.auth.uid);

      // Techs create own earnings
      allow create: if isActiveUser() &&
        dateIsUnlocked(request.resource.data.date) &&
        request.resource.data.techId == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'techId',
          'techName',
          'category',
          'amount',
          'note',
          'paymentType',
          'status',
          'approvedBy',
          'adminNote',
          'date',
          'createdAt',
          'reviewedAt'
        ]) &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0 &&
        request.resource.data.amount <= 1000000 &&
        request.resource.data.date is timestamp &&
        request.resource.data.approvedBy is string &&
        request.resource.data.adminNote is string &&
        (
          (inOutApprovalRequired() &&
            request.resource.data.status == 'pending' &&
            request.resource.data.approvedBy == '' &&
            request.resource.data.adminNote == '' &&
            request.resource.data.reviewedAt == null) ||
          (!inOutApprovalRequired() &&
            request.resource.data.status == 'approved' &&
            request.resource.data.reviewedAt is timestamp)
        );

      allow update: if (isAdmin() &&
        dateIsUnlocked(resource.data.date) &&
        dateIsUnlocked(request.resource.data.date) &&
        resource.data.status != 'approved') || (
        isActiveUser() &&
        dateIsUnlocked(resource.data.date) &&
        dateIsUnlocked(request.resource.data.date) &&
        resource.data.status == 'pending' &&
        resource.data.techId == request.auth.uid &&
        request.resource.data.techId == resource.data.techId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        inOutApprovalRequired() &&
        request.resource.data.status == 'pending' &&
        request.resource.data.approvedBy == '' &&
        request.resource.data.adminNote == '' &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'techName',
          'category',
          'amount',
          'note',
          'paymentType',
          'date',
          'status',
          'approvedBy',
          'adminNote',
          'reviewedAt'
        ])
      ) ||
      // Tech soft-archive: set isDeleted=true only, must not be approved, date unlocked
      (isActiveUser() &&
        resource.data.techId == request.auth.uid &&
        dateIsUnlocked(resource.data.date) &&
        resource.data.status != 'approved' &&
        request.resource.data.isDeleted == true &&
        request.resource.data.deletedAt is timestamp &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt'])
      ) ||
      // Admin restore: clear isDeleted flag
      (isAdmin() &&
        request.resource.data.isDeleted == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt'])
      );

      // Hard delete: admin only — techs must use archiveEarning() soft-delete instead
      allow delete: if isAdmin() &&
        dateIsUnlocked(resource.data.date) &&
        resource.data.status != 'approved';
    }

    // ─── AC Installs ───
    match /ac_installs/{installId} {
      match /history/{historyId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      allow read: if isAdmin() ||
        (isActiveUser() && resource.data.techId == request.auth.uid);

      allow create: if isActiveUser() &&
        dateIsUnlocked(request.resource.data.date) &&
        request.resource.data.techId == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'techId',
          'techName',
          'splitTotal',
          'splitShare',
          'windowTotal',
          'windowShare',
          'freestandingTotal',
          'freestandingShare',
          'note',
          'status',
          'approvedBy',
          'adminNote',
          'date',
          'createdAt',
          'reviewedAt'
        ]) &&
        request.resource.data.splitTotal is int &&
        request.resource.data.splitTotal >= 0 &&
        request.resource.data.splitShare is int &&
        request.resource.data.splitShare >= 0 &&
        request.resource.data.splitShare <= request.resource.data.splitTotal &&
        request.resource.data.windowTotal is int &&
        request.resource.data.windowTotal >= 0 &&
        request.resource.data.windowShare is int &&
        request.resource.data.windowShare >= 0 &&
        request.resource.data.windowShare <= request.resource.data.windowTotal &&
        request.resource.data.freestandingTotal is int &&
        request.resource.data.freestandingTotal >= 0 &&
        request.resource.data.freestandingShare is int &&
        request.resource.data.freestandingShare >= 0 &&
        request.resource.data.freestandingShare <= request.resource.data.freestandingTotal &&
        (request.resource.data.splitTotal + request.resource.data.windowTotal + request.resource.data.freestandingTotal) > 0 &&
        request.resource.data.techName is string &&
        request.resource.data.note is string &&
        request.resource.data.date is timestamp &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.approvedBy is string &&
        request.resource.data.adminNote is string &&
        (
          (inOutApprovalRequired() &&
            request.resource.data.status == 'pending' &&
            request.resource.data.approvedBy == '' &&
            request.resource.data.adminNote == '' &&
            request.resource.data.reviewedAt == null) ||
          (!inOutApprovalRequired() &&
            request.resource.data.status == 'approved' &&
            request.resource.data.reviewedAt is timestamp)
        );

      allow update: if (isAdmin() &&
        dateIsUnlocked(resource.data.date) &&
        dateIsUnlocked(request.resource.data.date) &&
        resource.data.status != 'approved') || (
        isActiveUser() &&
        dateIsUnlocked(resource.data.date) &&
        dateIsUnlocked(request.resource.data.date) &&
        resource.data.techId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.techId == resource.data.techId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.splitTotal is int &&
        request.resource.data.splitTotal >= 0 &&
        request.resource.data.splitShare is int &&
        request.resource.data.splitShare >= 0 &&
        request.resource.data.splitShare <= request.resource.data.splitTotal &&
        request.resource.data.windowTotal is int &&
        request.resource.data.windowTotal >= 0 &&
        request.resource.data.windowShare is int &&
        request.resource.data.windowShare >= 0 &&
        request.resource.data.windowShare <= request.resource.data.windowTotal &&
        request.resource.data.freestandingTotal is int &&
        request.resource.data.freestandingTotal >= 0 &&
        request.resource.data.freestandingShare is int &&
        request.resource.data.freestandingShare >= 0 &&
        request.resource.data.freestandingShare <= request.resource.data.freestandingTotal &&
        (request.resource.data.splitTotal + request.resource.data.windowTotal + request.resource.data.freestandingTotal) > 0 &&
        request.resource.data.techName is string &&
        request.resource.data.note is string &&
        inOutApprovalRequired() &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.approvedBy == '' &&
        request.resource.data.adminNote == '' &&
        request.resource.data.reviewedAt == null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'techName',
          'splitTotal',
          'splitShare',
          'windowTotal',
          'windowShare',
          'freestandingTotal',
          'freestandingShare',
          'note',
          'date',
          'status',
          'approvedBy',
          'adminNote',
          'reviewedAt'
        ])
      ) ||
      // Tech soft-archive: set isDeleted=true only, must not be approved, date unlocked
      (isActiveUser() &&
        resource.data.techId == request.auth.uid &&
        dateIsUnlocked(resource.data.date) &&
        resource.data.status != 'approved' &&
        request.resource.data.isDeleted == true &&
        request.resource.data.deletedAt is timestamp &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt'])
      ) ||
      // Admin restore: clear isDeleted flag
      (isAdmin() &&
        request.resource.data.isDeleted == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt'])
      );

      // Hard delete: admin only — techs must use archiveInstall() soft-delete instead
      allow delete: if isAdmin() &&
        dateIsUnlocked(resource.data.date) &&
        resource.data.status != 'approved';
    }

    // ─── Companies ───
    match /companies/{companyId} {
      allow read: if isAuth();
      allow create: if isAdmin() &&
        request.resource.data.keys().hasOnly([
          'name',
          'invoicePrefix',
          'isActive',
          'logoBase64',
          'createdAt'
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.invoicePrefix is string &&
        request.resource.data.isActive is bool &&
        request.resource.data.logoBase64 is string;
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'invoicePrefix',
          'isActive',
          'logoBase64'
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.invoicePrefix is string &&
        request.resource.data.isActive is bool &&
        request.resource.data.logoBase64 is string;
      allow delete: if isAdmin();
    }

    // ─── App Settings ───
    match /app_settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
