<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) data extraction rules.
    Excludes all app data from both cloud backup (Google One) and
    device-to-device transfers to prevent credential / token leakage.
    Note: android:fullBackupContent="false" covers API 30 and below;
    this file covers API 31+.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
